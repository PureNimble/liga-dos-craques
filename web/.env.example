# Supabase - valores públicos do frontend (seguros de expor no bundle; a segurança vem do RLS).
# Copia este ficheiro para .env.local e preenche com os valores do teu projeto Supabase.
# Painel Supabase → Project Settings → API

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Push notifications - chave pública VAPID (não é secreta). Gerar com
# `npx web-push generate-vapid-keys`; a chave privada fica só nos secrets da
# Edge Function `send-push`, nunca aqui. Opcional: sem ela, o toggle de
# notificações em Definições fica escondido.
VITE_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
